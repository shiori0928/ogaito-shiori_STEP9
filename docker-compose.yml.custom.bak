services:
  laravel.test:
    image: laravelsail/php82-composer
    ports:
      - '80:80'
    volumes:
      - ./:/var/www/html
    networks:
      - sail

  mysql:
    image: 'mysql:8.0'
    ports:
      - '3306:3306'
    environment:
      MYSQL_ROOT_PASSWORD: 'password'
      MYSQL_DATABASE: 'laravel'
      MYSQL_USER: 'sail'
      MYSQL_PASSWORD: 'password'
    networks:
      - sail
    volumes:
      - mysql-data:/var/lib/mysql

  phpmyadmin:
    image: phpmyadmin/phpmyadmin
    ports:
      - "8081:80"
    environment:
      PMA_HOST: mysql
      PMA_USER: sail
      PMA_PASSWORD: password
    networks:
      - sail

networks:
  sail:

volumes:
  mysql-data:
